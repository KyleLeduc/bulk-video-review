{
  // Friendly display name for the Claude Code focused devcontainer.
  "name": "Claude Code + Structurizr",
  "build": {
    "dockerfile": "Dockerfile"
  },
  // Forward the common Vite port; change or add ports for your own app.
  "forwardPorts": [
    5173
  ],
  "mounts": [
    // Keep dependencies inside a named Docker volume so rebuilds do not thrash host files.
    "source=${localWorkspaceFolderBasename}-node-modules,target=/workspaces/${localWorkspaceFolderBasename}/node_modules,type=volume",
    // Reuse the host git identity without baking secrets into the image.
    "source=${localEnv:HOME}/.gitconfig,target=/root/.gitconfig,type=bind"
  ],
  // Install project dependencies after the workspace is created, then sanity-check key CLIs.
  "postCreateCommand": "npm install && structurizr --help",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "eamodio.gitlens",
        "ms-azuretools.vscode-docker",
        "bpruitt-goddard.mermaid-markdown-syntax-highlighting",
        "bierner.markdown-mermaid",
        "MermaidChart.vscode-mermaid-chart",
        "systemticks.c4-dsl-extension"
      ]
    }
  },
  "features": {
    // Git inside the container keeps repo and worktree flows available to agents.
    "ghcr.io/devcontainers/features/git:1": {
      "ppa": true,
      "version": "latest"
    },
    // GitHub CLI stays available for repo automation from inside the container.
    "ghcr.io/devcontainers/features/github-cli:1": {
      "installDirectlyFromGitHubRelease": true,
      "version": "latest"
    },
    // Python is often useful for one-off automation and tooling scripts.
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    },
    // Chrome testing support enables browser automation and UI verification tools.
    "ghcr.io/kreemer/features/chrometesting:1": {},
    // Structurizr CLI runs on Java, so keep a JDK available in the container.
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17"
    }
  }
}
